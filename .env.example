# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin: comma-separated emails allowed to access /admin (optional; can use DB table instead)
ADMIN_EMAILS=admin@example.com

# Supabase service role key - ONLY use server-side for admin operations, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
